TELEGRAM_BOT_TOKEN=replace-me
TELEGRAM_ALLOWED_CHAT_IDS=123456789
CODEX_COMMAND=codex
CODEX_WORKDIR=.
CODEX_EXTRA_ARGS=["--search"]
# CODEX_EXTRA_ARGS=["--dangerously-bypass-approvals-and-sandbox","--search"]
# i recommend you to allow this one otherwise the app
# may not work without it, but i prefer you to do it by yourself 
VOICE_TO_CODEX_ENABLED=true
VOICE_MAX_DURATION_SECONDS=180
VOICE_MAX_FILE_BYTES=20971520
VOICE_TEMP_DIR=
FFMPEG_COMMAND=ffmpeg
WHISPER_COMMAND=whisper
WHISPER_MODEL=base
WHISPER_LANGUAGE=
WHISPER_DEVICE=auto
WHISPER_TASK=transcribe
WHISPER_TIMEOUT_MS=180000
WHISPER_FP16=false
OUTPUT_FLUSH_MS=1200
MAX_BUFFERED_CHARS=16000
REPO_PATH_PROMPT_TIMEOUT_MS=120000
TELEGRAM_MENU_WEBAPP_URL=
